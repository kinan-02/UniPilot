/*.pdf

# # Technion raw source files (local only — large, licensing-sensitive)
# services/data-engineering/data/raw/**/*.json
# services/data-engineering/data/raw/**/*.pdf
# !services/data-engineering/data/raw/**/README.md
# !services/data-engineering/data/raw/**/manifest.json

# # Local Obsidian / catalog vault (large PDFs + notes — not product code)
# services/data-engineering/data/catalog_valut/

# # Generated data-engineering artifacts (local extraction outputs)
# services/data-engineering/data/generated/**
# !services/data-engineering/data/generated/**/README.md

# Large generated quality reports (commit markdown summary or sample JSON only)
services/data-engineering/data/reports/technion/dds_staging_quality_report.json

# Editor / AI tooling (local only — not part of the product codebase)
.claude/
.cursor/
**/.claude/
**/.cursor/

# Graphify knowledge-graph artifacts (regenerated locally)
graphify-out/
**/graphify-out/
.graphify/
**/.graphify/

# Golden-set eval traces and local debug artifacts (services/agent only)
services/agent/tmp/
**/final_answer_eval_traces/
**/final_answer_eval_traces_raw/
**/raw_llm/
**/raw_llm_debug/

# Pytest live-eval dumps (large; one new timestamped JSON per run).
# Already-tracked runs stay tracked so teammates can pull them.
# To share a new run: git add -f services/ai/tests/agent_core/live_eval_logs/<file>.json
**/live_eval_logs/*.json
**/live_eval_logs/check.py

services/api/data/cache/wiki_embedding_index.json
services/api/data/cache/wiki_embedding_index.compact.pkl.gz
services/api/data/cache/wiki_embedding_index.meta.json
services/api/data/cache/backups/

# Agent service's own copy of the same generated embedding cache (Jul-2026 —
# services/agent is a standalone service with its own retrieval index build)
services/agent/data/cache/wiki_embedding_index.json
services/agent/data/cache/wiki_embedding_index.compact.pkl.gz
services/agent/data/cache/wiki_embedding_index.meta.json
services/agent/data/cache/backups/

# services/ai never had these rules, which is why its copy WAS committed --
# a 47MB pickle now permanently in history (b90865a). Wiki vectors live in
# Pinecone since dc1a432, so nothing should write here again; the pattern is
# kept broad so a regenerated cache cannot be committed by accident.
services/*/data/cache/
.mcp.json
CLAUDE.md
.claude-flow
