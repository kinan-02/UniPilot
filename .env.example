API_PORT=8000
WEB_PORT=3000
ENVIRONMENT=development
AUTO_SEED_CATALOG=false
MONGO_DB=unipilot_python
DATA_ENGINEERING_LOG_LEVEL=INFO
CATALOG_VAULT_PATH=data/catalog_valut
CATALOG_EXPORT_DIR=data/generated/technion/catalog
AI_SERVICE_PORT=3001
AGENT_SERVICE_PORT=3003
AGENT_TURN_TIMEOUT_SECONDS=180
INTERNAL_API_TIMEOUT_SECONDS=60
WORKER_PORT=3002
WORKER_QUEUE_NAME=ai_jobs
TRANSCRIPT_PARSER_PORT=8010
TRANSCRIPT_PARSER_URL=http://transcript-parser:8010
TRANSCRIPT_PARSER_TIMEOUT_SECONDS=60
TRANSCRIPT_IMPORT_MAX_UPLOAD_BYTES=5242880
TRANSCRIPT_IMPORT_RATE_LIMIT_WINDOW_MS=60000
TRANSCRIPT_IMPORT_RATE_LIMIT_MAX=10

CATALOG_CACHE_ENABLED=true
CATALOG_CACHE_TTL_SECONDS=300
CATALOG_OFFERINGS_BATCH_MAX=50

MONGO_ROOT_USERNAME=unipilot
MONGO_ROOT_PASSWORD=unipilot_dev_password

# Dev default works for docker compose first-run; use a unique 32+ char secret in production.
JWT_SECRET=unipilot_dev_jwt_secret_change_in_production
JWT_EXPIRES_IN=1h
BCRYPT_SALT_ROUNDS=12
AUTH_RATE_LIMIT_WINDOW_MS=60000
# Development/demo: 30; production deployments should set AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_MAX=30
# POST /academic-risks/analyze (AI); production: set AI_RATE_LIMIT_MAX=5
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=10
# GET /graduation-progress and /graduation-progress/curriculum-graph
PROGRESS_RATE_LIMIT_WINDOW_MS=60000
PROGRESS_RATE_LIMIT_MAX=60

# Comma-separated browser origins allowed to send credentialed requests (cookies).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000

# Browser URL where the web app is served (used for OAuth redirects).
WEB_APP_URL=http://localhost:3000

# Optional Google OAuth (leave blank to hide Google sign-in in the UI).
# Redirect URI defaults to ${WEB_APP_URL}/api/auth/google/callback
# Register that URI in Google Cloud Console → APIs & Services → Credentials.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# Playwright E2E only: stub Google OAuth callback codes (e2e|email|googleId). Never enable in production.
E2E_GOOGLE_OAUTH_STUB=false

# Optional Microsoft Outlook Mail integration (delegated OAuth via Microsoft Graph).
# Redirect URI defaults to ${WEB_APP_URL}/api/integrations/outlook/callback
# Register that URI in Azure Portal → App registrations → Authentication.
MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=
MICROSOFT_SCOPES="User.Read Mail.Read offline_access"
# Required when Outlook integration is enabled. Use a long random secret (32+ chars).
MICROSOFT_TOKEN_ENCRYPTION_KEY=

# Refresh token lifetime: session sign-in vs stay-signed-in (seconds).
REFRESH_TOKEN_SESSION_TTL_SECONDS=86400
REFRESH_TOKEN_REMEMBER_TTL_SECONDS=2592000

# Redis auth (required in Docker). Use a strong unique password in production.
REDIS_PASSWORD=unipilot_dev_redis_password

# Shared secret for internal worker -> AI calls. Required (32+ chars) when ENVIRONMENT=production.
INTERNAL_SERVICE_TOKEN=unipilot_dev_internal_service_token_change_in_production

# Technion semester offering JSON (semester planner dropdown). Mounted read-only in docker-compose.
TECHNION_RAW_DIR=/app/data/raw/technion
# Obsidian catalog wiki for UniPilot Agent hybrid retrieval (API service)
CATALOG_VAULT_WIKI_PATH=/app/data/academic/wiki

# Academic graph (AI service — wiki + semester offering JSON directory)
ACADEMIC_WIKI_PATH=/app/data/academic/wiki
ACADEMIC_TECHNION_RAW_DIR=/app/data/raw/technion
ACADEMIC_DEFAULT_SEMESTER_FILE=courses_2025_201.json
ACADEMIC_CATALOG_JSON=/app/data/raw/technion/courses_2025_201.json

# Foundation LLM (internal ai + mas services) — DeepSeek via OpenAI-compatible API
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_CHAT_MODEL=deepseek-v4-pro
ADVISOR_MAX_RETRIEVAL_ITERATIONS=5

# RAG embeddings (API service only) — LLMod (separate from chat LLM; do not reuse DeepSeek key)
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.llmod.ai/v1
EMBEDDING_MODEL=MB5R2CF-azure/text-embedding-3-small
EMBEDDING_ENABLED=true
EMBEDDING_INDEX_ENABLED=true
# Docker: /app/data/cache/wiki_embedding_index.json
# Local dev (from services/api): data/cache/wiki_embedding_index.json
EMBEDDING_INDEX_CACHE_PATH=data/cache/wiki_embedding_index.json
AGENT_LLM_VALIDATION_ENABLED=false
AGENT_LLM_EXPLANATION_ENABLED=true
AGENT_LLM_INTENT_FALLBACK_ENABLED=true
AGENT_LLM_PREFERENCE_EXTRACTION_ENABLED=true
AGENT_AGENTIC_RETRIEVAL_ENABLED=true
# Phase 3 — Task Understanding Agent (diagnostic only; does not affect routing yet)
AGENT_TASK_UNDERSTANDING_ENABLED=false
AGENT_TASK_UNDERSTANDING_DRY_RUN=true
# Phase 5 — Planner Agent (diagnostic/dry-run only; does not affect routing yet)
AGENT_PLANNER_ENABLED=false
AGENT_PLANNER_DRY_RUN=true
# Phase 6 — Supervisor Orchestrator Runtime (shadow/dry-run only; does not affect routing yet)
AGENT_SUPERVISOR_ENABLED=false
AGENT_SUPERVISOR_DRY_RUN=true
# Phase 7 — real read-only workflow adapters in shadow mode (still diagnostic only)
AGENT_SUPERVISOR_REAL_HANDLERS_ENABLED=false
# Added in Phase 7 as a placeholder; superseded by
# AGENT_SUPERVISOR_POST_CONTEXT_COMPARE_ENABLED below (Phase 8), which is the
# flag actually read for the live-vs-shadow comparison hook.
AGENT_SUPERVISOR_SHADOW_COMPARE_ENABLED=false
# Phase 8 — post-context/post-live-workflow Supervisor Shadow Compare + Validation
# (still diagnostic only; never affects the response, routing, or SSE events)
AGENT_SUPERVISOR_POST_CONTEXT_COMPARE_ENABLED=false
AGENT_SUPERVISOR_VALIDATION_ENABLED=false
# Phase 9 — Controlled Supervisor Promotion (off by default). Hard-restricted
# to graduation_progress_workflow regardless of AGENT_SUPERVISOR_PROMOTION_WORKFLOWS;
# the legacy deterministic response is always computed first and is always
# the fallback unless every strict promotion gate passes.
AGENT_SUPERVISOR_PROMOTION_ENABLED=false
AGENT_SUPERVISOR_PROMOTION_MODE=off
AGENT_SUPERVISOR_PROMOTION_WORKFLOWS=graduation_progress_workflow
# Phase 10 — read-only specialist-agent wrappers (shadow-only; off by default).
# When false, the three specialist capabilities stay registered but their
# handler returns a safe "skipped" result without ever calling ReasoningBlock.
AGENT_SPECIALIST_AGENTS_ENABLED=false
AGENT_SPECIALIST_AGENTS_DRY_RUN=true
# Phase 11 — Specialist Output Validation + Workflow-vs-Specialist Compare
# (deterministic, diagnostic only; never affects the response, routing, or
# SSE events; never requires OPENAI_API_KEY).
AGENT_SPECIALIST_VALIDATION_ENABLED=false
AGENT_SPECIALIST_COMPARE_ENABLED=false
# Phase 12 — Specialist Tool Observation Layer (deterministic, read-only,
# shadow-only; never affects the response, routing, or SSE events; never
# requires OPENAI_API_KEY). When false, deterministic_observations stays
# empty (byte-for-byte Phase 10/11 behavior).
AGENT_SPECIALIST_OBSERVATIONS_ENABLED=false
AGENT_SPECIALIST_OBSERVATION_MAX_COUNT=8
# Phase 13 — Bounded Specialist Tool-Request Loop (still shadow-only; never
# affects the response, routing, or SSE events). When false, a specialist
# ReasoningBlock pass that returns status="needs_tool" degrades to the exact
# Phase 10 fallback, unchanged. When true, specialists may request bounded,
# read-only Phase 12 observations (never arbitrary tools/writes/proposed
# actions). AGENT_SPECIALIST_TOOL_LOOP_MAX_ROUNDS is hard-capped at 2
# regardless of this value; AGENT_SPECIALIST_TOOL_LOOP_MAX_REQUESTS_PER_ROUND
# is hard-capped at 8. The loop itself never calls an LLM directly (only the
# existing Phase 12 observation builder) — only the specialist's own
# ReasoningBlock re-run needs OPENAI_API_KEY, same as Phase 10.
AGENT_SPECIALIST_TOOL_LOOP_ENABLED=false
AGENT_SPECIALIST_TOOL_LOOP_MAX_ROUNDS=1
AGENT_SPECIALIST_TOOL_LOOP_MAX_REQUESTS_PER_ROUND=4
# Phase 14 — Controlled Specialist Text Promotion (off by default). Hard-
# restricted to graduation_progress_agent regardless of
# AGENT_SPECIALIST_TEXT_PROMOTION_AGENTS; only response.text may ever be
# replaced (blocks/warnings/sources/proposed_actions always stay the live
# deterministic workflow's own). Always defers to Phase 9 workflow
# promotion when a workflow candidate was already promoted this turn.
# Modes: off | shadow_only | promote_validated.
AGENT_SPECIALIST_TEXT_PROMOTION_ENABLED=false
AGENT_SPECIALIST_TEXT_PROMOTION_MODE=off
AGENT_SPECIALIST_TEXT_PROMOTION_AGENTS=graduation_progress_agent
AGENT_SPECIALIST_TEXT_PROMOTION_MAX_CHARS=4000

# Phase 15 — Dynamic AgentSpec + Block Library + Agent Builder (shadow-only).
# When disabled, dynamic agents never run. When enabled, they still run only in
# shadow/dry-run mode and never affect final answers.
AGENT_DYNAMIC_AGENTS_ENABLED=false
AGENT_DYNAMIC_AGENTS_DRY_RUN=true

# Phase 16 — Monitor + Plan Assumption Tracking + Replan/Repair Signals (diagnostic-only).
# When disabled, no monitor diagnostics are attached. When enabled, monitor remains
# diagnostic-only and never affects final answers or triggers real replanning.
AGENT_MONITOR_ENABLED=false
AGENT_MONITOR_DRY_RUN=true
AGENT_CLARIFICATION_ENABLED=false
AGENT_CLARIFICATION_USER_FACING_ENABLED=false
AGENT_CLARIFICATION_MAX_QUESTIONS=3
AGENT_CLARIFICATION_BATCHING_ENABLED=false
AGENT_CLARIFICATION_MAX_QUESTIONS_PER_TURN=3
AGENT_CLARIFICATION_MAX_PENDING_TURNS=3
AGENT_CLARIFICATION_STATE_ENABLED=true

# Phase 19 — Warm Planner Invocation + Plan Repair Foundation (diagnostic/dry-run by default)
AGENT_PLAN_REPAIR_ENABLED=false
AGENT_PLAN_REPAIR_DRY_RUN=true
AGENT_PLAN_REPAIR_USE_LLM=false
AGENT_REPLAN_MAX_REPAIRS_PER_GOAL=2
AGENT_REPLAN_MAX_REGENERATIONS_PER_GOAL=1
AGENT_CLARIFICATION_EFFECTIVE_CONTEXT_ENABLED=false

# Phase 20 — Dynamic Planner AgentSpec Emission (diagnostic/shadow-only by default)
AGENT_PLANNER_DYNAMIC_SPECS_ENABLED=false
AGENT_PLANNER_DYNAMIC_SPECS_DRY_RUN=true
AGENT_PLANNER_DYNAMIC_SPECS_MAX_PER_PLAN=3
AGENT_PLANNER_DYNAMIC_SPECS_ALLOWED_PATTERNS=single_pass,tool_observation_loop,compare_and_synthesize
AGENT_PLANNER_DYNAMIC_SPECS_ALLOWED_RISK_LEVELS=low,medium

# Phase 21 — Synthesis / Final Answer Composer (diagnostic-only by default)
AGENT_SYNTHESIS_ENABLED=false
AGENT_SYNTHESIS_DRY_RUN=true
AGENT_SYNTHESIS_USE_LLM=false
AGENT_SYNTHESIS_MAX_EVIDENCE_ITEMS=12
AGENT_SYNTHESIS_MAX_CONFLICTS=6
AGENT_SYNTHESIS_MAX_CANDIDATE_CHARS=5000

# Phase 22 — Controlled synthesis text promotion (off by default)
AGENT_SYNTHESIS_TEXT_PROMOTION_ENABLED=false
AGENT_SYNTHESIS_TEXT_PROMOTION_MODE=off
AGENT_SYNTHESIS_TEXT_PROMOTION_WORKFLOWS=graduation_progress_workflow,course_question_workflow,requirement_explanation_workflow
AGENT_SYNTHESIS_TEXT_PROMOTION_MIN_CONFIDENCE=0.85
AGENT_SYNTHESIS_TEXT_PROMOTION_MAX_CHARS=5000
AGENT_SYNTHESIS_TEXT_PROMOTION_REQUIRE_BLOCKS=true

# Phase 25: runtime readiness gate (disabled by default — fail closed when enabled without manifest)
AGENT_RUNTIME_READINESS_GATE_ENABLED=false
AGENT_RUNTIME_READINESS_MANIFEST_PATH=
AGENT_RUNTIME_READINESS_REQUIRE_HUMAN_REVIEW=true
AGENT_RUNTIME_READINESS_MIN_LEVEL=ready_for_limited_promotion
AGENT_RUNTIME_READINESS_MAX_AGE_DAYS=30
AGENT_RUNTIME_READINESS_FAIL_CLOSED=true

# Phase 26: full LLM shadow replay lab (disabled by default — requires --allow-real-llm)
AGENT_EVAL_FULL_LLM_SHADOW_ENABLED=false
AGENT_EVAL_FULL_LLM_REQUIRE_EXPLICIT_ALLOW=true
AGENT_EVAL_FULL_LLM_MAX_CASES=20
AGENT_EVAL_FULL_LLM_MAX_REASONING_CALLS_PER_CASE=20
AGENT_EVAL_FULL_LLM_MAX_TOTAL_REASONING_CALLS=200
AGENT_EVAL_SIDE_EFFECT_FIREWALL_ENABLED=true
AGENT_EVAL_REPORT_CONTRACT_CALLS=true


EMBEDDING_INDEX_BATCH_SIZE=64

# Obsidian catalog wiki for agent hybrid retrieval
# Docker: /app/data/academic/wiki
CATALOG_VAULT_WIKI_PATH=../data-engineering/data/catalog_valut/catalog_valut/wiki

