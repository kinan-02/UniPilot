API_PORT=8000
WEB_PORT=3000
ENVIRONMENT=development
AUTO_SEED_CATALOG=false
MONGO_DB=unipilot_python
DATA_ENGINEERING_LOG_LEVEL=INFO
CATALOG_VAULT_PATH=data/catalog_valut
CATALOG_EXPORT_DIR=data/generated/technion/catalog
AI_SERVICE_PORT=3001
WORKER_PORT=3002
WORKER_QUEUE_NAME=ai_jobs
TRANSCRIPT_PARSER_PORT=8010
TRANSCRIPT_PARSER_URL=http://transcript-parser:8010
TRANSCRIPT_PARSER_TIMEOUT_SECONDS=60
TRANSCRIPT_IMPORT_MAX_UPLOAD_BYTES=5242880
TRANSCRIPT_IMPORT_RATE_LIMIT_WINDOW_MS=60000
TRANSCRIPT_IMPORT_RATE_LIMIT_MAX=10

CATALOG_CACHE_ENABLED=true
CATALOG_CACHE_TTL_SECONDS=300
CATALOG_OFFERINGS_BATCH_MAX=50

MONGO_ROOT_USERNAME=unipilot
MONGO_ROOT_PASSWORD=unipilot_dev_password

# Dev default works for docker compose first-run; use a unique 32+ char secret in production.
JWT_SECRET=unipilot_dev_jwt_secret_change_in_production
JWT_EXPIRES_IN=1h
BCRYPT_SALT_ROUNDS=12
AUTH_RATE_LIMIT_WINDOW_MS=60000
# Development/demo: 30; production deployments should set AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_MAX=30
# POST /academic-risks/analyze (AI); production: set AI_RATE_LIMIT_MAX=5
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=10
# GET /graduation-progress and /graduation-progress/curriculum-graph
PROGRESS_RATE_LIMIT_WINDOW_MS=60000
PROGRESS_RATE_LIMIT_MAX=60

# Comma-separated browser origins allowed to send credentialed requests (cookies).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000

# Browser URL where the web app is served (used for OAuth redirects).
WEB_APP_URL=http://localhost:3000

# Optional Google OAuth (leave blank to hide Google sign-in in the UI).
# Redirect URI defaults to ${WEB_APP_URL}/api/auth/google/callback
# Register that URI in Google Cloud Console → APIs & Services → Credentials.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# Playwright E2E only: stub Google OAuth callback codes (e2e|email|googleId). Never enable in production.
E2E_GOOGLE_OAUTH_STUB=false

# Optional Microsoft Outlook Mail integration (delegated OAuth via Microsoft Graph).
# Redirect URI defaults to ${WEB_APP_URL}/api/integrations/outlook/callback
# Register that URI in Azure Portal → App registrations → Authentication.
MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=
MICROSOFT_SCOPES="User.Read Mail.Read offline_access"
# Required when Outlook integration is enabled. Use a long random secret (32+ chars).
MICROSOFT_TOKEN_ENCRYPTION_KEY=

# Refresh token lifetime: session sign-in vs stay-signed-in (seconds).
REFRESH_TOKEN_SESSION_TTL_SECONDS=86400
REFRESH_TOKEN_REMEMBER_TTL_SECONDS=2592000

# Redis auth (required in Docker). Use a strong unique password in production.
REDIS_PASSWORD=unipilot_dev_redis_password

# Shared secret for internal worker -> AI calls. Required (32+ chars) when ENVIRONMENT=production.
INTERNAL_SERVICE_TOKEN=unipilot_dev_internal_service_token_change_in_production

# Technion semester offering JSON (semester planner dropdown). Mounted read-only in docker-compose.
TECHNION_RAW_DIR=/app/data/raw/technion
# Obsidian catalog wiki for UniPilot Agent hybrid retrieval (API service)
CATALOG_VAULT_WIKI_PATH=/app/data/academic/wiki

# Academic graph (AI service — wiki + semester offering JSON directory)
ACADEMIC_WIKI_PATH=/app/data/academic/wiki
ACADEMIC_TECHNION_RAW_DIR=/app/data/raw/technion
ACADEMIC_DEFAULT_SEMESTER_FILE=courses_2025_201.json
ACADEMIC_CATALOG_JSON=/app/data/raw/technion/courses_2025_201.json

# Foundation LLM (internal ai + mas services) — DeepSeek via OpenAI-compatible API
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_CHAT_MODEL=deepseek-v4-pro
ADVISOR_MAX_RETRIEVAL_ITERATIONS=5

# RAG embeddings (API service only) — LLMod (separate from chat LLM; do not reuse DeepSeek key)
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.llmod.ai/v1
EMBEDDING_MODEL=MB5R2CF-azure/text-embedding-3-small
EMBEDDING_ENABLED=true
EMBEDDING_INDEX_ENABLED=true
# Docker: /app/data/cache/wiki_embedding_index.json
# Local dev (from services/api): data/cache/wiki_embedding_index.json
EMBEDDING_INDEX_CACHE_PATH=data/cache/wiki_embedding_index.json
AGENT_LLM_VALIDATION_ENABLED=false
AGENT_LLM_EXPLANATION_ENABLED=true
AGENT_LLM_INTENT_FALLBACK_ENABLED=true
AGENT_LLM_PREFERENCE_EXTRACTION_ENABLED=true
AGENT_AGENTIC_RETRIEVAL_ENABLED=true
EMBEDDING_INDEX_BATCH_SIZE=64

# Obsidian catalog wiki for agent hybrid retrieval
# Docker: /app/data/academic/wiki
CATALOG_VAULT_WIKI_PATH=../data-engineering/data/catalog_valut/catalog_valut/wiki

# Multi-agent system (internal mas service)
MAS_SERVICE_PORT=3003
MAS_QUEUE_NAME=mas_agent_jobs
MAS_WORKER_ENABLED=true
MAS_MAX_NEGOTIATION_ROUNDS=4
MAS_PLANNER_MAX_TOOL_ITERATIONS=5
# Internal API URL for graduation-progress bridge (Docker default: http://api:8000)
API_SERVICE_URL=http://api:8000
API_REQUEST_TIMEOUT_SECONDS=30
# Optional MAS-specific LLM overrides. If unset, mas falls back to OPENAI_* above.
# MAS_OPENAI_API_KEY=
# MAS_OPENAI_BASE_URL=
# MAS_OPENAI_CHAT_MODEL=
